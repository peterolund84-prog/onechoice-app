# Copy to secrets.toml and replace with your real keys
# cp .streamlit/secrets.toml.example .streamlit/secrets.toml

# Supabase (Project Settings → API)
# IMPORTANT (GDPR): create the project in an EU region (e.g. Frankfurt / Stockholm).
# Region cannot be moved later. Run supabase/schema.sql (+ migrations/20260719_gdpr.sql
# and migrations/20260720_shopping_items.sql if the project was created from an older schema).
SUPABASE_URL = "https://YOUR_PROJECT_REF.supabase.co"
SUPABASE_KEY = "YOUR_SUPABASE_ANON_PUBLIC_KEY"
# Optional server-only fallback for account delete if RPC delete_own_account is missing.
# Never expose this in a public client — Streamlit secrets stay on the server.
# SUPABASE_SERVICE_ROLE_KEY = "eyJ..."

# Optional absolute privacy policy URL (otherwise in-app ?privacy=1 / PRIVACY.md)
# PRIVACY_URL = "https://example.com/integritet"

# Public app origin for share links (no trailing slash)
# APP_URL = "https://your-app.streamlit.app"

# Optional LLM + payments
# REQUIRED for fridge photo invent — must be a real xAI key (not this placeholder).
# Placeholder keys are rejected loudly; invent will NOT pretend the fridge was empty.
# Must start with xai- (from https://console.x.ai). Wrong/revoked keys fail loudly.
GROK_API_KEY = "xai-din_riktiga_nyckel_här"
# Optional: pin a fast model (skips boot probe). Recommended for snappy decides.
# TEXT_MODEL = "grok-4-fast"
STRIPE_SECRET_KEY = "din_stripe_secret_key_här"
